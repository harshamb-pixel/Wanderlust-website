<% layout("/layouts/boilerplate") %>
<div class="row">
    <div class="col-8 offset-2" >
    <h2>Create a New Listing</h2>
    <form method="POST" action="/listings" novalidate class="needs-validation">
        <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input name="listing[title]"
        placeholder="Add title"
        type="text" required
        class="form-control"
        />
        <div class="invalid-feedback">Enter the valid Title</div>
        </div>
        
        <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea
            name="listing[description]"
            placeholder="Enter description"
            type="text" required
            class="form-control"
        ></textarea>
        <div class="invalid-feedback">Enter the short Description</div>
        </div>
        
        <div class="mb-3">
            <label for="image" class="form-label">Image URL</label>
            <input name="listing[image]"
            placeholder="Enter image URL"
            type="text" required
            class="form-control" />
            <div class="invalid-feedback">Enter the valid Url</div>
        </div>
        <div class="row">
            <div class="col-4">
                <div class="mb-3"   >
                <label for="Price" class="form-label">Price</label>
                <input name="listing[price]" placeholder="1200" type="number" required class="form-control" />
            <div class="invalid-feedback">Enter the valid Price</div>
            </div>
         </div>

         <div class="col-8">
            <div class="mb-3">
                    <label for="location" class="form-label">Location</label>
                    <input name="listing[location]" placeholder="Tumkur, Karnataka" type="text" required class="form-control" />
                <div class="invalid-feedback">Enter the valid Location</div>
                </div>
            </div>
        </div>

        <div class="mb-3">
        <label for="country" class="form-label">Country</label>
        <input name="listing[country]" placeholder="India" type="text" required class="form-control" />
        <div class="invalid-feedback">Enter the valid Country</div>
    </div>

        <br><br>

        <button type="submit" class="add-btn">ADD</button>
    </form>
    </div>
</div>

